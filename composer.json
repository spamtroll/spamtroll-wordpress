{
    "name": "spamtroll/wordpress-plugin",
    "description": "Spamtroll Anti-Spam plugin for WordPress.",
    "type": "wordpress-plugin",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../spamtroll-php-sdk",
            "options": {
                "symlink": false
            }
        }
    ],
    "require": {
        "php": ">=8.0",
        "spamtroll/php-sdk": "*"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
